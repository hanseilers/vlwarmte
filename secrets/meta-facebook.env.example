# Meta / Facebook — Graph API (system user + app)
#
# 1. Kopieer dit bestand naar:  secrets/meta-facebook.env
# 2. Vul de waarden in (zonder aanhalingstekens rond de token).
# 3. secrets/meta-facebook.env staat in .gitignore — wordt niet gecommit.
#
# Plak tokens liever in dat lokale bestand dan in een chat; chats worden gelogd.
#
# META_GRAPH_ACCESS_TOKEN = het token dat je krijgt bij System user → Generate token
#   (Meta koppelt app + scopes + page-assets; dit is de string die je als access_token= meestuurt).

META_GRAPH_ACCESS_TOKEN=

# Numerieke Facebook Page ID
META_PAGE_ID=

# Optioneel: App ID (handig voor foutmeldingen / support)
META_APP_ID=

# Graph API-versie in requests (pas aan als Meta dat vraagt)
META_GRAPH_API_VERSION=v21.0
